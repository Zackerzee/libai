DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=15000

# 通义千问 / 阿里云百炼。没有配置时会自动跳过。
QWEN_API_KEY=your-qwen-or-dashscope-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT_MS=15000

# 文心千帆 / 百度千帆。没有配置时会自动跳过。
QIANFAN_API_KEY=your-qianfan-api-key
QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2/chat/completions
QIANFAN_MODEL=ernie-speed-8k
QIANFAN_TIMEOUT_MS=15000

# Google Gemini，可选兜底。没有配置时会自动跳过。
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_MS=15000

PRINT_ADMIN_PIN=change-this-pin
