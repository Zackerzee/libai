DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=15000

# 国内 OpenAI 兼容模型，可用阿里云百炼 / 百度千帆等。没有配置时会自动跳过。
DOMESTIC_AI_API_KEY=your-domestic-openai-compatible-api-key
DOMESTIC_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
DOMESTIC_AI_MODEL=qwen-plus
DOMESTIC_AI_TIMEOUT_MS=15000

# Google Gemini，可选兜底。没有配置时会自动跳过。
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_MS=15000

PRINT_ADMIN_PIN=change-this-pin
