{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/nfc",
      "destination": "/nfc/index.html"
    },
    {
      "source": "/mentor-timer",
      "destination": "/mentor-timer/index.html"
    },
    {
      "source": "/print",
      "destination": "/print/index.html"
    },
    {
      "source": "/admin/print-orders",
      "destination": "/admin/print-orders/index.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "nfc.libms.net"
        }
      ],
      "destination": "/nfc/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; connect-src 'self' data: blob:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ]
}
