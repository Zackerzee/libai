{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/download-windows-bridge.js": {
      "includeFiles": "downloads/libms-niimbot-windows-bridge.zip"
    }
  },
  "rewrites": [
    {
      "source": "/nfc",
      "destination": "/nfc/index.html"
    },
    {
      "source": "/mentor-timer",
      "destination": "/mentor-timer/index.html"
    },
    {
      "source": "/mentor-timer-preview",
      "destination": "/mentor-timer-anchor/index.html"
    },
    {
      "source": "/mentor-timer-anchor",
      "destination": "/mentor-timer-anchor/index.html"
    },
    {
      "source": "/print",
      "destination": "/print/index.html"
    },
    {
      "source": "/admin/print-orders",
      "destination": "/admin/print-orders/index.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "nfc.libms.net"
        }
      ],
      "destination": "/nfc/index.html"
    }
  ],
  "headers": [
    {
      "source": "/downloads/libms-niimbot-windows-bridge.zip",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/zip"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"libms-niimbot-windows-bridge.zip\""
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; connect-src 'self' data: blob: http://127.0.0.1:17888 http://localhost:17888; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ]
}
