# 复制本文件为 printer.env。
# 默认 auto：打印前自动扫描 COM 口并逐个握手，选出真正有响应的精臣标签机。
# 如需强制指定，也可以改成 COM3 / COM4 / COM5。
LIBMS_NIIMBOT_PORT=auto

# Windows 蓝牙 COM 口经常会超时或抛 Operation aborted。
# 默认不尝试蓝牙口；如果你明确要走蓝牙，再改成 1。
LIBMS_TRY_BLUETOOTH_PORTS=0

# 本机打印桥端口。网页计时器会请求 http://127.0.0.1:17888/print-label
LIBMS_PRINT_PORT=17888

# Python 命令。普通 Windows 安装通常使用 python。
# 一键脚本会优先写成 LIBMS_PYTHON_BIN=py + LIBMS_PYTHON_ARGS=-3.12，
# 这样可以避开 Windows Store 的 Python 入口和不兼容的 Python 3.14。
# 如果你安装在固定路径，也可以写成 C:\Users\你的用户名\AppData\Local\Programs\Python\Python312\python.exe
LIBMS_PYTHON_BIN=python
LIBMS_PYTHON_ARGS=

# 标签中文字体。Windows 默认建议用微软雅黑。
LIBMS_LABEL_FONT=C:\Windows\Fonts\msyh.ttc

# 打印模式：
# serial          优先使用 USB/蓝牙 COM 串口协议；如配置了 Windows 打印机名，串口失败后会自动用系统队列兜底。
# serial-only     只使用串口，失败也不走 Windows 打印队列。
# auto/windows-printer 不推荐，容易被 Windows 打印机驱动或 DYMO 队列干扰。
LIBMS_PRINT_METHOD=serial

# 可选：NIIMBOT B3S-P 的 Windows 打印机名称。
# 一键脚本会自动识别。留空则不会使用 Windows 队列兜底。
LIBMS_WINDOWS_PRINTER_NAME=
